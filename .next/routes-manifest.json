{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blogs/[slug]",
      "regex": "^/blogs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blogs/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product/[slug]",
      "regex": "^/product/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/product/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/profile/orders/[id]",
      "regex": "^/profile/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/profile/orders/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/profile/orders/[id]/invoice",
      "regex": "^/profile/orders/([^/]+?)/invoice(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/profile/orders/(?<nxtPid>[^/]+?)/invoice(?:/)?$"
    }
  ],
