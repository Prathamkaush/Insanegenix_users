{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/authenticity/layout,_N_T_/authenticity/page,_N_T_/authenticity"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/authenticity/__PAGE__",
    "/authenticity",
    "/_index",
    "/_head"
  ]
}